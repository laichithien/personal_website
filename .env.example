# ===========================================
# The Transparent Core - Environment Variables
# ===========================================

# Database (port 5442 to avoid conflict with local postgres)
DATABASE_URL=postgresql://postgres:postgres@localhost:5442/ai_agent_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=ai_agent_db

# OpenRouter AI
OPENROUTER_API_KEY=your_openrouter_api_key_here

# For Pydantic-AI OpenAI compatibility with OpenRouter
OPENAI_API_KEY=your_openrouter_api_key_here
OPENAI_BASE_URL=https://openrouter.ai/api/v1

# Default Model (OpenRouter format)
DEFAULT_MODEL=xiaomi/mimo-v2-flash:free
DEFAULT_TEMPERATURE=0.7

# Application
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:3333

# Rate Limiting
RATE_LIMIT_PER_MINUTE=30

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:3334
NEXT_PUBLIC_SITE_URL=http://localhost:3333

# ===========================================
# Admin Panel Configuration
# ===========================================

# Admin Credentials (used on first startup to create admin user)
ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=admin123

# JWT Authentication
JWT_SECRET_KEY=your-super-secret-jwt-key-change-in-production-use-random-string
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# File Upload (for knowledge documents)
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=10
